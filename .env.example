# Copia questo file in .env e compila i valori reali
# Il file .env NON viene mai committato su git

# ── Sicurezza sessione ────────────────────────────────────────────────────────
# Genera una chiave casuale con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-questa-chiave-in-produzione

# ── URL base del sito (senza slash finale) ────────────────────────────────────
# In locale: http://localhost:8080
# In produzione: https://tuodominio.com
APP_URL=http://localhost:8080

# ── Reset password via email ──────────────────────────────────────────────────
# Usa la tua email Gmail come mittente.
# Per MAIL_PASSWORD NON usare la password Gmail normale:
#   vai su myaccount.google.com → Sicurezza → Verifica in due passaggi (attiva)
#   poi → Password per le app → crea una password per "Posta"
MAIL_FROM=tua@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Google OAuth ──────────────────────────────────────────────────────────────
# console.cloud.google.com → API e servizi → Credenziali
# → Crea credenziali → ID client OAuth → Applicazione web
# Aggiungi come "URI di reindirizzamento autorizzato": APP_URL/auth/google/callback
GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# ── Facebook OAuth ────────────────────────────────────────────────────────────
# developers.facebook.com → La tua app → Impostazioni → Base
# Aggiungi in "URI di reindirizzamento OAuth validi": APP_URL/auth/facebook/callback
FACEBOOK_APP_ID=123456789012345
FACEBOOK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
